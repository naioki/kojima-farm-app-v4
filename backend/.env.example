# Supabase（フロントと共有）
NEXT_PUBLIC_SUPABASE_URL=https://hynedtzwxuinruxsxvlm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# テナント（single-tenant 構成）
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# メール設定（Supabase email_config テーブルが空の場合のフォールバック）
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SENDER_FILTER=fax@example.com
EMAIL_DAYS_BACK=1

# Discord & LINE Works Webhook 設定
DISCORD_WEBHOOK_URL=your-discord-webhook-url-here
LINE_WORKS_BOT_ID=your-line-works-bot-id-here
LINE_WORKS_API_TOKEN=your-line-works-api-token-here
ALLOWED_LINE_USERS=user_id_1,user_id_2
ALLOWED_DISCORD_USERS=user_id_1,user_id_2

